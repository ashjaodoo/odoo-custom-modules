<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="email_template_portal_credentials" model="mail.template">
            <field name="name">Job Application — Portal Access Credentials</field>
            <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
            <field name="subject">✅ Application Received — Your Portal Access Details</field>
            <field name="email_from">{{ (object.company_id.email or user.email) }}</field>
            <field name="email_to">{{ object.email_from }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; background: #ffffff;">

    <!-- Header -->
    <div style="background: linear-gradient(135deg, #2c7be5, #1a56c4); padding: 36px 32px; text-align: center; border-radius: 8px 8px 0 0;">
        <h1 style="color: #ffffff; margin: 0; font-size: 24px; font-weight: 700;">
            Application Received! 🎉
        </h1>
        <p style="color: #c9dcf7; margin: 8px 0 0; font-size: 15px;">
            Thank you for applying. We've set up your personal portal.
        </p>
    </div>

    <!-- Body -->
    <div style="padding: 32px; border: 1px solid #e8ecf0; border-top: none; border-radius: 0 0 8px 8px;">

        <p style="font-size: 16px; color: #374151; margin-top: 0;">
            Dear <strong>{{ object.partner_name }}</strong>,
        </p>

        <p style="font-size: 15px; color: #4b5563; line-height: 1.6;">
            We have received your application for the position of
            <strong style="color: #2c7be5;">{{ object.job_id.name }}</strong>.
            You can track your application status in real-time through your personal portal.
        </p>

        <!-- Application Summary Box -->
        <div style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 20px; margin: 24px 0;">
            <h3 style="margin: 0 0 16px; color: #1e293b; font-size: 15px;">📋 Application Summary</h3>
            <table style="width: 100%; border-collapse: collapse;">
                <tr>
                    <td style="padding: 6px 0; color: #64748b; font-size: 14px; width: 40%;">Position Applied</td>
                    <td style="padding: 6px 0; color: #1e293b; font-size: 14px; font-weight: 600;">{{ object.job_id.name }}</td>
                </tr>
                <tr>
                    <td style="padding: 6px 0; color: #64748b; font-size: 14px;">Applicant Name</td>
                    <td style="padding: 6px 0; color: #1e293b; font-size: 14px;">{{ object.partner_name }}</td>
                </tr>
                <tr>
                    <td style="padding: 6px 0; color: #64748b; font-size: 14px;">Current Status</td>
                    <td style="padding: 6px 0;">
                        <span style="background: #dbeafe; color: #1d4ed8; padding: 3px 10px; border-radius: 20px; font-size: 13px; font-weight: 600;">
                            {{ object.stage_id.name or 'New' }}
                        </span>
                    </td>
                </tr>
            </table>
        </div>

        <!-- Credentials Box -->
        <div style="background: #fffbeb; border: 1px solid #fcd34d; border-radius: 8px; padding: 20px; margin: 24px 0;">
            <h3 style="margin: 0 0 16px; color: #92400e; font-size: 15px;">🔑 Your Portal Login Credentials</h3>
            <table style="width: 100%; border-collapse: collapse;">
                <tr>
                    <td style="padding: 8px 0; color: #78350f; font-size: 14px; width: 40%;">Portal URL</td>
                    <td style="padding: 8px 0; font-size: 14px;">
                        <a href="{{ ctx.get('portal_url', '') }}" style="color: #2c7be5; font-weight: 600;">
                            Click here to access portal
                        </a>
                    </td>
                </tr>
                <tr>
                    <td style="padding: 8px 0; color: #78350f; font-size: 14px;">Email / Username</td>
                    <td style="padding: 8px 0; color: #1e293b; font-size: 14px; font-weight: 600;">{{ object.email_from }}</td>
                </tr>
                <tr>
                    <td style="padding: 8px 0; color: #78350f; font-size: 14px;">Temporary Password</td>
                    <td style="padding: 8px 0;">
                        <code style="background: #fef3c7; padding: 4px 10px; border-radius: 4px; font-size: 15px; font-weight: 700; color: #92400e; letter-spacing: 1px;">
                            {{ ctx.get('temp_password', '') }}
                        </code>
                    </td>
                </tr>
            </table>
            <p style="margin: 12px 0 0; font-size: 12px; color: #92400e;">
                ⚠️ Please change your password after first login for security.
            </p>
        </div>

        <!-- CTA Button -->
        <div style="text-align: center; margin: 28px 0;">
            <a href="{{ ctx.get('portal_url', '') }}"
               style="background: #2c7be5; color: #ffffff; padding: 14px 36px; border-radius: 8px;
                      text-decoration: none; font-size: 16px; font-weight: 700; display: inline-block;">
                🚀 View My Application Status
            </a>
        </div>

        <!-- What to Expect -->
        <div style="border-left: 3px solid #2c7be5; padding-left: 16px; margin: 24px 0;">
            <h4 style="margin: 0 0 8px; color: #1e293b; font-size: 14px;">What happens next?</h4>
            <ul style="margin: 0; padding-left: 16px; color: #4b5563; font-size: 14px; line-height: 1.8;">
                <li>Our HR team will review your application</li>
                <li>You can check your status anytime in the portal</li>
                <li>Stages: New → 1st Interview → 2nd Interview → Hired</li>
                <li>We will contact you for interview scheduling</li>
            </ul>
        </div>

        <hr style="border: none; border-top: 1px solid #e2e8f0; margin: 24px 0;"/>

        <p style="font-size: 13px; color: #9ca3af; margin: 0;">
            This email was sent automatically upon receiving your job application.
            If you did not apply, please ignore this email.
        </p>
    </div>
</div>
            ]]></field>
            <field name="auto_delete">True</field>
        </record>

    </data>
</odoo>
