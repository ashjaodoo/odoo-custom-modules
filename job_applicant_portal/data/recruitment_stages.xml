<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Recruitment Stages -->
        <record id="stage_new" model="hr.recruitment.stage">
            <field name="name">New</field>
            <field name="sequence">1</field>
            <field name="fold">False</field>
            <field name="hired_stage">False</field>
        </record>

        <record id="stage_first_interview" model="hr.recruitment.stage">
            <field name="name">1st Interview</field>
            <field name="sequence">2</field>
            <field name="fold">False</field>
            <field name="hired_stage">False</field>
        </record>

        <record id="stage_second_interview" model="hr.recruitment.stage">
            <field name="name">2nd Interview</field>
            <field name="sequence">3</field>
            <field name="fold">False</field>
            <field name="hired_stage">False</field>
        </record>

        <record id="stage_on_hold" model="hr.recruitment.stage">
            <field name="name">On Hold</field>
            <field name="sequence">4</field>
            <field name="fold">True</field>
            <field name="hired_stage">False</field>
        </record>

        <record id="stage_hired" model="hr.recruitment.stage">
            <field name="name">Hired</field>
            <field name="sequence">5</field>
            <field name="fold">False</field>
            <field name="hired_stage">True</field>
        </record>

        <record id="stage_rejected" model="hr.recruitment.stage">
            <field name="name">Rejected</field>
            <field name="sequence">6</field>
            <field name="fold">True</field>
            <field name="hired_stage">False</field>
        </record>

    </data>
</odoo>
